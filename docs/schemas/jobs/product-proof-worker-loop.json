{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schema://jobs/product-proof-worker-loop",
  "title": "Product Proof Worker Loop",
  "description": "Structured evidence from the hosted product-proof worker loop.",
  "type": "object",
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "output": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "complete"
      ]
    },
    "job_id": {
      "type": "string",
      "minLength": 1
    },
    "completed_at": {
      "type": "string",
      "minLength": 1
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "warn",
              "fail"
            ]
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "name",
          "status",
          "evidence"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "summary",
    "output",
    "status",
    "checks"
  ],
  "additionalProperties": false
}
