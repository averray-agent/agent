# ---------------------------------------------------------------------------
# B-04 (audit): Caddy is the edge proxy — clients connect to it directly (there
# is no CDN or tunnel in front). Overwrite any client-supplied X-Forwarded-For
# with the real connecting IP before proxying upstream, so the backend's
# TRUST_PROXY rate-limit key (and any other XFF consumer) can't be spoofed by a
# forged header. Imported into every reverse_proxy block below.
# ---------------------------------------------------------------------------
(strip_forwarded_for) {
  header_up X-Forwarded-For {http.request.remote.host}
}

# Main public site
# Serves the marketing / trust / schemas-lite surface from the repo's `site/`
# folder, including robots/sitemap/llms and the discovery manifest. Public
# agent profiles live on the main domain, with `/agents/:wallet` rewritten to
# the static profile shell that hydrates itself from
# https://api.averray.com/agents/:wallet.
averray.com, www.averray.com {
  root * /srv/site
  encode zstd gzip

  handle /.well-known/* {
    file_server
  }

  @agentProfile path_regexp agentProfile ^/agents/(0x[a-fA-F0-9]{40})/?$
  rewrite @agentProfile /agent.html?wallet={re.agentProfile.1}

  file_server
}

# Operator app
# Static frontend shell with same-origin `/api/*` and `/index/*` proxy paths so
# the browser never talks to the API/indexer origins directly during normal app
# usage. To protect this surface with browser basic auth, generate the live
# Caddyfile through `scripts/ops/render-caddyfile.sh` instead of copying this
# template directly.
app.averray.com {
  encode zstd gzip

  handle /api/events* {
    uri strip_prefix /api
    reverse_proxy backend:8787 {
      import strip_forwarded_for
      flush_interval -1
      transport http {
        read_timeout 0
      }
    }
  }

  handle_path /api/* {
    reverse_proxy backend:8787 {
      import strip_forwarded_for
    }
  }

  handle_path /index/* {
    reverse_proxy indexer:42069 {
      import strip_forwarded_for
    }
  }

  root * /srv/frontend
  file_server
}

# Backend API
api.averray.com {
  encode zstd gzip

  handle /events* {
    reverse_proxy backend:8787 {
      import strip_forwarded_for
      flush_interval -1
      transport http {
        read_timeout 0
      }
    }
  }

  reverse_proxy backend:8787 {
    import strip_forwarded_for
  }
}

# Indexer
index.averray.com {
  encode zstd gzip
  reverse_proxy indexer:42069 {
    import strip_forwarded_for
  }
}
